{
  "swagger": "2.0",
  "info": {
    "title": "Fitness Workout API",
    "description": "Fitness workout planner API",
    "version": "1.0.0"
  },
  "host": "localhost:3000",
  "basePath": "/",
  "schemes": ["http"],
  "paths": {
    "/api/workouts": {
      "get": {
        "summary": "Get all workouts",
        "responses": {
          "200": {
            "description": "List of workouts"
          }
        }
      },
      "post": {
        "summary": "Create a new workout",
        "parameters": [
          {
            "in": "body",
            "name": "workout",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Workout"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Workout created"
          },
          "400": {
            "description": "Invalid workout data"
          }
        }
      }
    },
    "/api/workouts/{id}": {
      "get": {
        "summary": "Get workout by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Workout found"
          },
          "404": {
            "description": "Workout not found"
          }
        }
      },
      "put": {
        "summary": "Update workout by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "workout",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Workout"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Workout updated"
          },
          "400": {
            "description": "Invalid workout data"
          },
          "404": {
            "description": "Workout not found"
          }
        }
      },
      "delete": {
        "summary": "Delete workout by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Workout deleted"
          },
          "404": {
            "description": "Workout not found"
          }
        }
      }
    }
  },
  "definitions": {
    "Workout": {
      "type": "object",
      "required": [
        "title",
        "description",
        "difficulty",
        "durationMinutes",
        "exercises",
        "muscleGroups"
      ],
      "properties": {
        "title": {
          "type": "string",
          "example": "Leg Day"
        },
        "description": {
          "type": "string",
          "example": "Lower body workout"
        },
        "difficulty": {
          "type": "string",
          "example": "medium"
        },
        "durationMinutes": {
          "type": "number",
          "example": 45
        },
        "exercises": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "example": ["Squats", "Lunges"]
        },
        "muscleGroups": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "example": ["legs", "glutes"]
        },
        "equipment": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "example": ["Dumbbells"]
        }
      }
    }
  }
}