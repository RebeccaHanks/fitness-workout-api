{
  "swagger": "2.0",
  "info": {
    "title": "Fitness Workout API",
    "description": "Fitness workout planner API",
    "version": "1.0.0"
  },
  "host": "localhost:3000",
  "basePath": "/",
  "schemes": ["http"],
  "securityDefinitions": {
  "Bearer": {
    "type": "apiKey",
    "name": "Authorization",
    "in": "header",
    "description": "Enter: Bearer your-token-here"
  }
},
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Register a new user",
        "parameters": [
          {
            "in": "body",
            "name": "user",
            "required": true,
            "schema": {
              "$ref": "#/definitions/User"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "User registered successfully"
          },
          "400": {
            "description": "User already exists"
          }
        }
      }
    },

    "/api/auth/login": {
      "post": {
        "summary": "Login user",
        "parameters": [
          {
            "in": "body",
            "name": "credentials",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "email",
                "password"
              ],
              "properties": {
                "email": {
                  "type": "string",
                  "example": "rebecca@test.com"
                },
                "password": {
                  "type": "string",
                  "example": "password123"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Login successful"
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },

    "/api/workouts": {
      "get": {
        "summary": "Get all workouts",
        "responses": {
          "200": {
            "description": "List of workouts"
          }
        }
      },
      "post": {
        "summary": "Create a new workout",
        "security": [
          {
            "Bearer": []
          }
        ],
        "parameters": [
          {
            "in": "body",
            "name": "workout",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Workout"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Workout created"
          },
          "400": {
            "description": "Invalid workout data"
          }
        }
      }
    },

    "/api/workouts/{id}": {
      "get": {
        "summary": "Get workout by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Workout found"
          },
          "404": {
            "description": "Workout not found"
          }
        }
      },

      "put": {
        "summary": "Update workout by ID",
        "security": [
          {
            "Bearer": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "workout",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Workout"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Workout updated"
          },
          "400": {
            "description": "Invalid workout data"
          },
          "404": {
            "description": "Workout not found"
          }
        }
      },

      "delete": {
        "summary": "Delete workout by ID",
        "security": [
          {
            "Bearer": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Workout deleted"
          },
          "404": {
            "description": "Workout not found"
          }
        }
      }
    }
  },

  "definitions": {
    "User": {
      "type": "object",
      "required": [
        "name",
        "email",
        "password"
      ],
      "properties": {
        "name": {
          "type": "string",
          "example": "Rebecca Hanks"
        },
        "email": {
          "type": "string",
          "example": "rebecca@test.com"
        },
        "password": {
          "type": "string",
          "example": "password123"
        }
      }
    },

    "Workout": {
      "type": "object",
      "required": [
        "title",
        "description",
        "difficulty",
        "durationMinutes",
        "exercises",
        "muscleGroups"
      ],
      "properties": {
        "title": {
          "type": "string",
          "example": "Leg Day"
        },
        "description": {
          "type": "string",
          "example": "Lower body workout"
        },
        "difficulty": {
          "type": "string",
          "example": "medium"
        },
        "durationMinutes": {
          "type": "number",
          "example": 45
        },
        "exercises": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "example": [
            "Squats",
            "Lunges"
          ]
        },
        "muscleGroups": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "example": [
            "legs",
            "glutes"
          ]
        },
        "equipment": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "example": [
            "Dumbbells"
          ]
        }
      }
    }
  }
}